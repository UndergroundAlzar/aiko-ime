# Aiko IME 配置文件 / Configuration File

[general]
# 开机自启动 / Launch at startup
# 设置中心保存时会同步 HKCU Run 注册表项 / The settings center syncs the HKCU Run key on save
auto_start = false
# 语言 / Language
language = "zh-CN"
# 是否保存本地听写历史（默认关闭）/ Save local dictation history (off by default)
history_log_enabled = false
# 历史文件路径 / History file path
history_log_path = "dictation_history.jsonl"

[audio]
# 留空使用 Windows 默认麦克风 / Empty uses the Windows default microphone
input_device = ""

[hotkey]
# 热键模式: "combo" (组合键) 或 "double_tap" (双击)
# Hotkey mode: "combo" or "double_tap"
mode = "double_tap"
# 组合键，当 mode = "combo" 时生效 / Combo hotkey, used when mode = "combo"
combo_key = "Ctrl+Shift+V"
# 双击键，当 mode = "double_tap" 时生效 / Double-tap key, used when mode = "double_tap"
double_tap_key = "Ctrl"
# 双击间隔，单位毫秒 / Double-tap interval in milliseconds
double_tap_interval = 300

[floating_button]
# 是否显示悬浮按钮 / Show floating control
enabled = true
# 悬浮按钮位置，单位像素 / Floating control position in pixels
position_x = 100
position_y = 100
# 弹簧动画参数 / Spring animation parameters
stiffness = 180.0
damping = 12.0

[desktop_pet]
# 是否默认显示桌宠 / Show the desktop pet by default
enabled = true
# 桌宠位置，-1 表示自动放在屏幕右下角 / Desktop pet position; -1 means bottom-right auto placement
position_x = -1
position_y = -1
# 桌宠尺寸，单位像素 / Desktop pet size in pixels
size = 160

[asr]
# 识别后端: "online" 或 "offline" / Recognition backend: "online" or "offline"
backend = "online"
# 在线服务；当前支持 doubao / Online provider; currently supports doubao
online_provider = "doubao"
# 离线引擎；当前支持 sherpa_onnx / Offline provider; currently supports sherpa_onnx
offline_provider = "sherpa_onnx"
# 离线模型目录，需包含 aiko-sherpa-model.json / Offline model directory, must contain aiko-sherpa-model.json
offline_model_dir = "models/sherpa-onnx"
# 是否启用 VAD，语音活动检测 / Enable VAD, voice activity detection
vad_enabled = true

[ai]
# AI 润色与翻译总开关 / Master switch for AI formatting and translation
enabled = false
api_key = ""
api_endpoint = "https://api.openai.com/v1"
model = "gpt-3.5-turbo"
post_process_enabled = false
post_process_prompt = "Correct spelling, grammar, punctuation, and formatting while keeping the original meaning. Output only the corrected text."
translation_enabled = false
translation_prompt = "Translate Chinese to English or English to Chinese. Output only the translated text."

# 自定义词典：左侧是识别文本，右侧是替换文本
# Custom vocabulary: recognized text on the left, replacement on the right
[custom_vocabulary]
# "爱可" = "Aiko"
